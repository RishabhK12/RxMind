# Gemini API key is NO LONGER used client-side. Set it only as a secret in the Cloudflare Worker.
# (This line intentionally removed to prevent accidental leakage.)

# Backend proxy base URL (no trailing slash), e.g.:
# BACKEND_BASE_URL=

# Optional shared secret; if set, the app will send it as x-api-key and the worker must match it.
# BACKEND_SHARED_SECRET=
