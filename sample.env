# All fields are optional. The app now ships with a production Cloudflare Worker URL
# baked in, so you only need to set these if you are testing against your own worker.

# Backend proxy base URL (no trailing slash), e.g.:
# BACKEND_BASE_URL=https://your-worker.workers.dev

# Optional shared secret; if set, the app will send it as x-api-key and the worker must match it.
# BACKEND_SHARED_SECRET=super-secret
